# Development defaults. Replace all secrets before deployment.
NOVA_ENVIRONMENT=development
NOVA_APP_NAME=NOVA Assistive Backend
NOVA_API_V1_PREFIX=/api/v1

# Docker compose sets PostgreSQL. Local quick-run can use SQLite.
NOVA_DATABASE_URL=sqlite:///./nova_dev.db
# NOVA_DATABASE_URL=postgresql+psycopg://nova:nova_password@postgres:5432/nova

# Generate production values with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
NOVA_SECRET_KEY=change-me-access-secret-at-least-32-bytes
NOVA_REFRESH_SECRET_KEY=change-me-refresh-secret-at-least-32-bytes
NOVA_AES_GCM_KEY_B64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

NOVA_ACCESS_TOKEN_MINUTES=1440
NOVA_REFRESH_TOKEN_DAYS=30
NOVA_PASSWORD_BCRYPT_ROUNDS=12
NOVA_RATE_LIMIT_PER_MINUTE=60
NOVA_MODEL_STORE_PATH=./model_store
NOVA_SCENE_PROVIDER=simulated
NOVA_FACE_MATCH_THRESHOLD=0.75
NOVA_LARGE_GALLERY_THRESHOLD=20
NOVA_MAX_SCENE_IMAGE_KB=512
NOVA_CORS_ORIGINS=*
